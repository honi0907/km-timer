<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="KmTimer.Controls.HexColorPickerField"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:KmTimer.Helpers"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Top">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <StackPanel Spacing="4">
        <TextBlock
            x:Name="HeaderLabel"
            Text="{x:Bind Header, Mode=OneWay}"
            FontSize="12"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Visibility="{x:Bind HasHeader, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

        <Button
            x:Name="SwatchButton"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            MinHeight="36"
            Padding="10,6"
            AutomationProperties.Name="{x:Bind Header, Mode=OneWay}">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border
                    Width="28"
                    Height="28"
                    CornerRadius="4"
                    BorderBrush="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    <Rectangle x:Name="Swatch" RadiusX="3" RadiusY="3" />
                </Border>
                <TextBlock
                    Grid.Column="1"
                    Text="{x:Bind SelectedHex, Mode=OneWay}"
                    VerticalAlignment="Center"
                    Opacity="0.7"
                    FontSize="12" />
            </Grid>
            <Button.Flyout>
                <Flyout Placement="Bottom">
                    <ColorPicker
                        x:Name="Picker"
                        IsAlphaEnabled="False"
                        IsColorChannelTextInputVisible="False"
                        IsColorPreviewVisible="True"
                        ColorSpectrumShape="Ring"
                        ColorChanged="Picker_ColorChanged" />
                </Flyout>
            </Button.Flyout>
        </Button>
    </StackPanel>
</UserControl>
