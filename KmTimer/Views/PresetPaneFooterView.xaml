<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="KmTimer.Views.PresetPaneFooterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:KmTimer.ViewModels">

    <Border
        Padding="12,10"
        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
        BorderThickness="0,1,0,0">
        <StackPanel Spacing="10">
            <TextBlock
                Text="プリセット"
                FontSize="12"
                FontWeight="SemiBold"
                Opacity="0.75" />

            <StackPanel Spacing="8">
                <StackPanel Spacing="4">
                    <TextBlock
                        Text="{x:Bind ViewModel.PresetLabel1, Mode=OneWay}"
                        FontSize="11"
                        LineHeight="16"
                        TextWrapping="Wrap" />
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="保存" Padding="4,4" FontSize="11" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.SavePresetCommand}" CommandParameter="1" AutomationProperties.AutomationId="SavePreset1" />
                        <Button Grid.Column="1" Content="読込" Padding="4,4" FontSize="11" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" Command="{x:Bind ViewModel.LoadPresetCommand}" CommandParameter="1" AutomationProperties.AutomationId="LoadPreset1" />
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock
                        Text="{x:Bind ViewModel.PresetLabel2, Mode=OneWay}"
                        FontSize="11"
                        LineHeight="16"
                        TextWrapping="Wrap" />
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="保存" Padding="4,4" FontSize="11" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.SavePresetCommand}" CommandParameter="2" AutomationProperties.AutomationId="SavePreset2" />
                        <Button Grid.Column="1" Content="読込" Padding="4,4" FontSize="11" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" Command="{x:Bind ViewModel.LoadPresetCommand}" CommandParameter="2" AutomationProperties.AutomationId="LoadPreset2" />
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock
                        Text="{x:Bind ViewModel.PresetLabel3, Mode=OneWay}"
                        FontSize="11"
                        LineHeight="16"
                        TextWrapping="Wrap" />
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="保存" Padding="4,4" FontSize="11" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.SavePresetCommand}" CommandParameter="3" AutomationProperties.AutomationId="SavePreset3" />
                        <Button Grid.Column="1" Content="読込" Padding="4,4" FontSize="11" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" Command="{x:Bind ViewModel.LoadPresetCommand}" CommandParameter="3" AutomationProperties.AutomationId="LoadPreset3" />
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock
                        Text="{x:Bind ViewModel.PresetLabel4, Mode=OneWay}"
                        FontSize="11"
                        LineHeight="16"
                        TextWrapping="Wrap" />
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="保存" Padding="4,4" FontSize="11" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.SavePresetCommand}" CommandParameter="4" AutomationProperties.AutomationId="SavePreset4" />
                        <Button Grid.Column="1" Content="読込" Padding="4,4" FontSize="11" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" Command="{x:Bind ViewModel.LoadPresetCommand}" CommandParameter="4" AutomationProperties.AutomationId="LoadPreset4" />
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock
                        Text="{x:Bind ViewModel.PresetLabel5, Mode=OneWay}"
                        FontSize="11"
                        LineHeight="16"
                        TextWrapping="Wrap" />
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="保存" Padding="4,4" FontSize="11" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.SavePresetCommand}" CommandParameter="5" AutomationProperties.AutomationId="SavePreset5" />
                        <Button Grid.Column="1" Content="読込" Padding="4,4" FontSize="11" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" Command="{x:Bind ViewModel.LoadPresetCommand}" CommandParameter="5" AutomationProperties.AutomationId="LoadPreset5" />
                    </Grid>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
