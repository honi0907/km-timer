<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="KmTimer.Views.SystemSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:KmTimer.Controls"
    xmlns:vm="using:KmTimer.ViewModels"
    HorizontalAlignment="Stretch"
    HorizontalContentAlignment="Stretch">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalContentAlignment="Stretch">
        <StackPanel Spacing="12">
            <TextBlock Text="システム設定" Style="{StaticResource SubtitleTextBlockStyle}" />

            <Grid
                HorizontalAlignment="Stretch"
                ColumnSpacing="12"
                RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <controls:HexColorPickerField
                    Grid.Row="0"
                    Grid.Column="0"
                    Header="背景色"
                    SelectedHex="{x:Bind ViewModel.BgColor, Mode=TwoWay}"
                    AutomationProperties.AutomationId="BgColorBox" />
                <ComboBox
                    x:Name="ClockPositionBox"
                    Grid.Row="0"
                    Grid.Column="1"
                    Header="時計位置"
                    ItemsSource="{x:Bind ViewModel.ClockPositionOptions}"
                    DisplayMemberPath="Label"
                    HorizontalAlignment="Stretch"
                    SelectionChanged="ClockPositionBox_SelectionChanged"
                    AutomationProperties.AutomationId="ClockPositionBox" />

                <controls:HexColorPickerField
                    Grid.Row="1"
                    Grid.Column="0"
                    Header="時計色"
                    SelectedHex="{x:Bind ViewModel.ClockColor, Mode=TwoWay}"
                    AutomationProperties.AutomationId="ClockColorBox" />
                <ToggleSwitch
                    Grid.Row="1"
                    Grid.Column="1"
                    Header="現在時刻を表示"
                    VerticalAlignment="Bottom"
                    IsOn="{x:Bind ViewModel.ClockVisible, Mode=TwoWay}"
                    AutomationProperties.AutomationId="ClockToggle" />

                <Slider
                    Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Header="時計サイズ"
                    Minimum="1"
                    Maximum="10"
                    StepFrequency="0.5"
                    Value="{x:Bind ViewModel.ClockSize, Mode=TwoWay}"
                    AutomationProperties.AutomationId="ClockSizeSlider" />
            </Grid>

            <Border
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                Padding="12"
                CornerRadius="6"
                BorderThickness="1"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="バージョン / 更新" FontWeight="SemiBold" />
                    <TextBlock
                        x:Name="VersionInfoText"
                        Text="{x:Bind ViewModel.AppVersionText}"
                        Opacity="0.8" />
                    <Button
                        x:Name="OnlineUpdateButton"
                        Content="オンライン更新を確認"
                        HorizontalAlignment="Left"
                        Click="OnlineUpdateButton_Click"
                        AutomationProperties.AutomationId="OnlineUpdate" />
                    <TextBlock
                        x:Name="UpdateStatusText"
                        Opacity="0.7"
                        FontSize="12"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
