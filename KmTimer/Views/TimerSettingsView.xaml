<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="KmTimer.Views.TimerSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:KmTimer.Controls"
    xmlns:vm="using:KmTimer.ViewModels"
    HorizontalAlignment="Stretch"
    HorizontalContentAlignment="Stretch">

    <UserControl.Resources>
        <SolidColorBrush x:Key="TimerStartActiveBrush" Color="#10B981" />
        <SolidColorBrush x:Key="TimerStartActiveHoverBrush" Color="#059669" />
        <SolidColorBrush x:Key="TimerStartActivePressedBrush" Color="#047857" />
        <SolidColorBrush x:Key="TimerPauseActiveBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="TimerPauseActiveHoverBrush" Color="#D97706" />
        <SolidColorBrush x:Key="TimerPauseActivePressedBrush" Color="#B45309" />

        <Style x:Key="TimerStartActiveButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="RootBorder"
                            Background="{StaticResource TimerStartActiveBrush}"
                            BorderBrush="{StaticResource TimerStartActiveBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TimerStartActiveHoverBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TimerStartActiveHoverBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TimerStartActivePressedBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TimerStartActivePressedBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled" />
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter
                                Content="{TemplateBinding Content}"
                                Foreground="{TemplateBinding Foreground}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TimerPauseActiveButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="RootBorder"
                            Background="{StaticResource TimerPauseActiveBrush}"
                            BorderBrush="{StaticResource TimerPauseActiveBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TimerPauseActiveHoverBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TimerPauseActiveHoverBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TimerPauseActivePressedBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TimerPauseActivePressedBrush}" />
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled" />
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter
                                Content="{TemplateBinding Content}"
                                Foreground="{TemplateBinding Foreground}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="タイマー (Timer)" Style="{StaticResource SubtitleTextBlockStyle}" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalContentAlignment="Stretch" Margin="0,12,0,12">
            <Grid
                HorizontalAlignment="Stretch"
                ColumnSpacing="12"
                RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <NumberBox
                    Grid.Row="0"
                    Grid.Column="0"
                    Header="分"
                    Minimum="0"
                    HorizontalAlignment="Stretch"
                    SpinButtonPlacementMode="Compact"
                    Value="{x:Bind ViewModel.TimerMinutes, Mode=TwoWay}"
                    AutomationProperties.AutomationId="TimerMinutes" />
                <NumberBox
                    Grid.Row="0"
                    Grid.Column="1"
                    Header="秒"
                    Minimum="0"
                    Maximum="59"
                    HorizontalAlignment="Stretch"
                    SpinButtonPlacementMode="Compact"
                    Value="{x:Bind ViewModel.TimerSeconds, Mode=TwoWay}"
                    AutomationProperties.AutomationId="TimerSeconds" />

                <ToggleSwitch
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Header="0秒後にカウントアップ"
                    IsOn="{x:Bind ViewModel.CountUpAfterZero, Mode=TwoWay}"
                    AutomationProperties.AutomationId="CountUpToggle" />

                <controls:HexColorPickerField
                    Grid.Row="2"
                    Grid.Column="0"
                    Header="通常色"
                    SelectedHex="{x:Bind ViewModel.ColorNormal, Mode=TwoWay}"
                    AutomationProperties.AutomationId="ColorNormal" />
                <controls:HexColorPickerField
                    Grid.Row="2"
                    Grid.Column="1"
                    Header="警告色"
                    SelectedHex="{x:Bind ViewModel.ColorWarning, Mode=TwoWay}"
                    AutomationProperties.AutomationId="ColorWarning" />

                <controls:HexColorPickerField
                    Grid.Row="3"
                    Grid.Column="0"
                    Header="終了色"
                    SelectedHex="{x:Bind ViewModel.ColorDanger, Mode=TwoWay}"
                    AutomationProperties.AutomationId="ColorDanger" />
                <NumberBox
                    Grid.Row="3"
                    Grid.Column="1"
                    Header="警告(秒)"
                    Minimum="0"
                    HorizontalAlignment="Stretch"
                    Value="{x:Bind ViewModel.WarningSeconds, Mode=TwoWay}"
                    AutomationProperties.AutomationId="WarningSeconds" />

                <Slider
                    Grid.Row="4"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Header="タイマーサイズ"
                    Minimum="8"
                    Maximum="35"
                    StepFrequency="1"
                    Value="{x:Bind ViewModel.TimerSize, Mode=TwoWay}"
                    AutomationProperties.AutomationId="TimerSizeSlider" />
            </Grid>
        </ScrollViewer>

        <Grid
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    Content="-1分"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.AdjustTimerCommand}"
                    CommandParameter="-60"
                    AutomationProperties.AutomationId="TimerMinus1Min" />
                <Button
                    Grid.Column="1"
                    Content="+1分"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.AdjustTimerCommand}"
                    CommandParameter="60"
                    AutomationProperties.AutomationId="TimerPlus1Min" />
                <Button
                    Grid.Column="2"
                    Content="-10秒"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.AdjustTimerCommand}"
                    CommandParameter="-10"
                    AutomationProperties.AutomationId="TimerMinus10Sec" />
                <Button
                    Grid.Column="3"
                    Content="+10秒"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.AdjustTimerCommand}"
                    CommandParameter="10"
                    AutomationProperties.AutomationId="TimerPlus10Sec" />
                <Button
                    Grid.Column="4"
                    Content="-1秒"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.AdjustTimerCommand}"
                    CommandParameter="-1"
                    AutomationProperties.AutomationId="TimerMinus1Sec" />
                <Button
                    Grid.Column="5"
                    Content="+1秒"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.AdjustTimerCommand}"
                    CommandParameter="1"
                    AutomationProperties.AutomationId="TimerPlus1Sec" />
            </Grid>

            <Grid
                Grid.Row="1"
                HorizontalAlignment="Stretch"
                ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="TimerStartPauseButton"
                    Grid.Column="0"
                    Content="▶ / ⏸ START"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.ToggleTimerStartPauseCommand}"
                    AutomationProperties.AutomationId="TimerStartPause" />
                <Button
                    Grid.Column="1"
                    Content="Reset"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.ResetTimerCommand}"
                    AutomationProperties.AutomationId="TimerReset" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
