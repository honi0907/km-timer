<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="KmTimer.Views.KanpeSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:KmTimer.Controls"
    xmlns:vm="using:KmTimer.ViewModels"
    HorizontalAlignment="Stretch"
    HorizontalContentAlignment="Stretch">

    <UserControl.Resources>
        <SolidColorBrush x:Key="KanpeReleaseNormalBrush" Color="#EF4444" />
        <SolidColorBrush x:Key="KanpeReleaseHoverBrush" Color="#DC2626" />
        <SolidColorBrush x:Key="KanpeReleasePressedBrush" Color="#B91C1C" />

        <Style x:Key="KanpeSendButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="KanpeReleaseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="48" />
            <Setter Property="MinWidth" Value="48" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="UseSystemFocusVisuals" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="RootBorder"
                            Background="{StaticResource KanpeReleaseNormalBrush}"
                            BorderBrush="{StaticResource KanpeReleaseNormalBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                Content="{TemplateBinding Content}"
                                Foreground="{TemplateBinding Foreground}"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource KanpeReleaseHoverBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource KanpeReleaseHoverBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource KanpeReleasePressedBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="BorderBrush">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource KanpeReleasePressedBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="カンペ (Teleprompter)" Style="{StaticResource SubtitleTextBlockStyle}" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,12,0,12">
            <Grid ColumnSpacing="8" RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    x:Name="KanpeCard1"
                    Grid.Row="0"
                    Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    Padding="8"
                    CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="スタンバイ枠 1" Opacity="0.7" FontSize="12" FontWeight="Bold" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="KanpeInput1"
                                MinHeight="48"
                                Text="{x:Bind ViewModel.KanpeText1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                GotFocus="KanpeInput1_GotFocus"
                                TextChanged="KanpeInput1_TextChanged"
                                AutomationProperties.AutomationId="KanpeInput1" />
                            <Button
                                x:Name="KanpeSend1"
                                Grid.Column="1"
                                Content="{x:Bind ViewModel.KanpeSendLabel1, Mode=OneWay}"
                                VerticalAlignment="Top"
                                Click="KanpeSendButton_Click"
                                Tag="1"
                                AutomationProperties.AutomationId="KanpeSend1" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    x:Name="KanpeCard2"
                    Grid.Row="0"
                    Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    Padding="8"
                    CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="スタンバイ枠 2" Opacity="0.7" FontSize="12" FontWeight="Bold" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="KanpeInput2"
                                MinHeight="48"
                                Text="{x:Bind ViewModel.KanpeText2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                GotFocus="KanpeInput2_GotFocus"
                                TextChanged="KanpeInput2_TextChanged"
                                AutomationProperties.AutomationId="KanpeInput2" />
                            <Button
                                x:Name="KanpeSend2"
                                Grid.Column="1"
                                Content="{x:Bind ViewModel.KanpeSendLabel2, Mode=OneWay}"
                                VerticalAlignment="Top"
                                Click="KanpeSendButton_Click"
                                Tag="2"
                                AutomationProperties.AutomationId="KanpeSend2" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    x:Name="KanpeCard3"
                    Grid.Row="1"
                    Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    Padding="8"
                    CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="スタンバイ枠 3" Opacity="0.7" FontSize="12" FontWeight="Bold" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="KanpeInput3"
                                MinHeight="48"
                                Text="{x:Bind ViewModel.KanpeText3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                GotFocus="KanpeInput3_GotFocus"
                                TextChanged="KanpeInput3_TextChanged"
                                AutomationProperties.AutomationId="KanpeInput3" />
                            <Button
                                x:Name="KanpeSend3"
                                Grid.Column="1"
                                Content="{x:Bind ViewModel.KanpeSendLabel3, Mode=OneWay}"
                                VerticalAlignment="Top"
                                Click="KanpeSendButton_Click"
                                Tag="3"
                                AutomationProperties.AutomationId="KanpeSend3" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    x:Name="KanpeCard4"
                    Grid.Row="1"
                    Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    Padding="8"
                    CornerRadius="6"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="スタンバイ枠 4" Opacity="0.7" FontSize="12" FontWeight="Bold" />
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="KanpeInput4"
                                MinHeight="48"
                                Text="{x:Bind ViewModel.KanpeText4, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                GotFocus="KanpeInput4_GotFocus"
                                TextChanged="KanpeInput4_TextChanged"
                                AutomationProperties.AutomationId="KanpeInput4" />
                            <Button
                                x:Name="KanpeSend4"
                                Grid.Column="1"
                                Content="{x:Bind ViewModel.KanpeSendLabel4, Mode=OneWay}"
                                VerticalAlignment="Top"
                                Click="KanpeSendButton_Click"
                                Tag="4"
                                AutomationProperties.AutomationId="KanpeSend4" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <Grid
            Grid.Row="2"
            HorizontalAlignment="Stretch"
            RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <controls:HexColorPickerField
                    Grid.Column="0"
                    Header="文字色"
                    SelectedHex="{x:Bind ViewModel.KanpeColor, Mode=TwoWay}"
                    AutomationProperties.AutomationId="KanpeColor" />
                <Slider
                    Grid.Column="1"
                    Header="サイズ"
                    VerticalAlignment="Bottom"
                    Minimum="2"
                    Maximum="15"
                    StepFrequency="0.5"
                    Value="{x:Bind ViewModel.KanpeFontSize, Mode=TwoWay}"
                    AutomationProperties.AutomationId="KanpeFontSize" />
            </Grid>
            <Button
                x:Name="KanpeBgBlinkButton"
                Grid.Row="1"
                HorizontalAlignment="Stretch"
                Content="{x:Bind ViewModel.KanpeBgBlinkLabel, Mode=OneWay}"
                Click="KanpeBgBlinkButton_Click"
                AutomationProperties.AutomationId="KanpeBgBlink" />
        </Grid>
    </Grid>
</UserControl>
