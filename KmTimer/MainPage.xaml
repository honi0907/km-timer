<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="KmTimer.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:KmTimer.Controls"
    xmlns:helpers="using:KmTimer.Helpers"
    xmlns:views="using:KmTimer.Views"
    xmlns:vm="using:KmTimer.ViewModels">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <NavigationView
        x:Name="NavView"
        PaneDisplayMode="Left"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        OpenPaneLength="240"
        CompactPaneLength="52"
        SelectionChanged="NavView_SelectionChanged">

        <NavigationView.Resources>
            <StaticResource x:Key="NavigationViewExpandedPaneBackground" ResourceKey="SolidBackgroundFillColorBaseBrush" />
            <StaticResource x:Key="NavigationViewDefaultPaneBackground" ResourceKey="SolidBackgroundFillColorBaseBrush" />
            <StaticResource x:Key="NavigationViewContentBackground" ResourceKey="SolidBackgroundFillColorTertiaryBrush" />
            <StaticResource x:Key="NavigationViewGridSeparatorForeground" ResourceKey="ControlStrongStrokeColorDefaultBrush" />
            <StaticResource x:Key="NavigationViewItemBackgroundSelected" ResourceKey="SubtleFillColorTertiaryBrush" />
            <StaticResource x:Key="NavigationViewItemBackgroundPointerOver" ResourceKey="SubtleFillColorSecondaryBrush" />
        </NavigationView.Resources>

        <NavigationView.MenuItems>
            <NavigationViewItem Content="タイマー" Tag="timer" AutomationProperties.AutomationId="NavTimer">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Clock" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="カンペ" Tag="kanpe" AutomationProperties.AutomationId="NavKanpe">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Comment" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="システム" Tag="system" AutomationProperties.AutomationId="NavSystem">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Setting" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <NavigationView.PaneFooter>
            <views:PresetPaneFooterView />
        </NavigationView.PaneFooter>

        <Grid
            Padding="16,8,16,16"
            RowSpacing="12"
            Background="{ThemeResource SolidBackgroundFillColorTertiaryBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Preview (always visible) -->
            <Grid
                Grid.Row="0"
                ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Grid.Column="0"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Translation="0,0,16">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="カンペプレビュー (16:9)" FontWeight="SemiBold" Opacity="0.8" />
                            <TextBlock
                                Text="{x:Bind ViewModel.KanpeDraftBadgeText, Mode=OneWay}"
                                Foreground="#EAB308"
                                FontWeight="Bold"
                                Visibility="{x:Bind ViewModel.IsKanpeDraftBadgeVisible, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                        <Border Height="240" CornerRadius="4">
                            <Viewbox Stretch="Uniform">
                                <Border Width="1280" Height="720">
                                    <controls:DisplaySurface IsDraftPreview="True" DataContext="{x:Bind ViewModel}" />
                                </Border>
                            </Viewbox>
                        </Border>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Translation="0,0,16">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <StackPanel Spacing="8">
                        <TextBlock Text="出力プレビュー (16:9)" FontWeight="SemiBold" Opacity="0.8" />
                        <Border
                            x:Name="PreviewHost"
                            Height="240"
                            CornerRadius="4">
                            <Viewbox Stretch="Uniform">
                                <Border Width="1280" Height="720">
                                    <controls:DisplaySurface DataContext="{x:Bind ViewModel}" />
                                </Border>
                            </Viewbox>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Detail (switches by menu selection) -->
            <Border
                Grid.Row="1"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource ControlStrongStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Translation="0,0,16">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <ContentPresenter x:Name="DetailPresenter" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" />
            </Border>

            <InfoBar
                Grid.Row="1"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                IsOpen="{x:Bind ViewModel.IsToastVisible, Mode=OneWay}"
                IsClosable="False"
                Severity="Informational"
                Title="{x:Bind ViewModel.ToastMessage, Mode=OneWay}"
                Margin="0,0,0,8" />
        </Grid>
    </NavigationView>
</Page>
